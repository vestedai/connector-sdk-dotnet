# Vested AI Connector configuration
# Copy to .env and fill in real values before running.

# Required: connector JWT issued by the Vested AI platform.
VESTED_CONNECTOR_TOKEN=

# Required: hub gRPC endpoint in host:port form.
VESTED_CONNECTOR_HUB=hub.example.com:4443

# Optional: logging verbosity (Trace | Debug | Information | Warning | Error).
LOG_LEVEL=Information
